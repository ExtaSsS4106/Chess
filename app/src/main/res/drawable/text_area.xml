<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Состояние "в фокусе" (когда поле активно, курсор мигает) -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="#D3C9C9" />   <!-- чуть темнее, чем обычное -->
            <corners
                android:topLeftRadius="5dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="5dp"
                android:bottomRightRadius="0dp" />
            <stroke android:width="2dp" android:color="#8EEF44" /> <!-- зелёная обводка -->
        </shape>
    </item>

    <!-- Состояние "нажато" (пока палец на поле) -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#C0B8B8" />   <!-- ещё темнее -->
            <corners
                android:topLeftRadius="5dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="5dp"
                android:bottomRightRadius="0dp" />
            <stroke android:width="2dp" android:color="#6BB835" />
        </shape>
    </item>

    <!-- Обычное состояние (по умолчанию) -->
    <item>
        <shape>
            <solid android:color="#EAE1E1" />
            <corners
                android:topLeftRadius="5dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="5dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</selector>